{"version":2,"width":96,"height":28,"timestamp":1765850400,"env":{"SHELL":"/bin/bash","TERM":"xterm-256color"},"title":"cc-tmux start/status/capture/stop workflow"}
[0.100,"o","$ cd ~/projects/example-app\r\n"]
[0.600,"o","$ cc-tmux start . --name demo --prompt \"Summarize this repo and wait for follow-up.\"\r\n"]
[1.100,"o","created session: cc-tmux-demo\r\nproject: /home/user/projects/example-app\r\n"]
[1.700,"o","$ cc-tmux status demo --json\r\n"]
[2.200,"o","{\r\n  \"capture\": \"Claude Code is reading the repository...\\n> \",\r\n  \"done\": true,\r\n  \"exists\": true,\r\n  \"identifier\": \"demo\",\r\n  \"last_prompt_ready\": true,\r\n  \"session\": \"cc-tmux-demo\"\r\n}\r\n"]
[2.900,"o","$ cc-tmux send demo \"Create CONTROL_MODE_RESULT.md with a one-line note.\"\r\n"]
[3.300,"o","sent prompt to cc-tmux-demo\r\n"]
[4.100,"o","$ cc-tmux capture demo -n 12 --no-ansi\r\n"]
[4.700,"o","Claude Code is reading the repository...\r\n> Create CONTROL_MODE_RESULT.md with a one-line note.\r\nWrote CONTROL_MODE_RESULT.md\r\n> \r\n"]
[5.400,"o","$ cc-tmux stop demo --fallback-kill\r\n"]
[6.000,"o","stopped cc-tmux-demo\r\n"]
[6.500,"o","$ cc-tmux status demo --json\r\n"]
[7.000,"o","{\r\n  \"capture\": \"\",\r\n  \"done\": false,\r\n  \"exists\": false,\r\n  \"identifier\": \"demo\",\r\n  \"last_prompt_ready\": false,\r\n  \"session\": \"cc-tmux-demo\"\r\n}\r\n"]
